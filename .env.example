# Copy this file to .env and fill in your values.
# cp .env.example .env

# -------------------------------------------------------
# LLM API — Required
# -------------------------------------------------------
# Your OpenAI API key (or any OpenAI-compatible API key)
LLM_API_KEY="sk-proj-..."

# Optional: Override the base URL for a custom/local LLM endpoint (e.g., vLLM, Ollama)
# Leave empty to use the default OpenAI API (https://api.openai.com)
LLM_API_URL=

# Models to use (must be available on your chosen API endpoint)
LLM_LARGE_MODEL=gpt-4o
LLM_SMALL_MODEL=gpt-4o-mini

# -------------------------------------------------------
# Database — Do NOT change this for Docker Compose usage
# -------------------------------------------------------
# This is automatically overridden inside Docker Compose to point to the
# internal Postgres container. Only change this if you're running locally
# outside of Docker.
DATABASE_URL=postgresql+asyncpg://admin:admin@localhost:5432/policies

# -------------------------------------------------------
# Debugging
# -------------------------------------------------------
# Set to True to log the full prompts sent to and responses received from the LLM.
# Useful for debugging incorrect extractions.
LOG_PROMPTS=False
